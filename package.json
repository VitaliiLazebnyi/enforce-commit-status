{
  "name": "enforce-commit-status",
  "version": "1.0.0",
  "description": "Synchronous gatekeeper action; suspends build runner pending definitive test resolution.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\""
  },
  "keywords": [
    "actions",
    "github",
    "status"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
